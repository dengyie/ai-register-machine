# ChatGPT provider — copy env, do not commit secrets
#
# Egress switch (pick one backend):
#   core   = project mihomo under .nodes/ (:17897) — no Clash Verge
#   clash  = external Clash/mihomo (:7897)
#   list   = only nodes.json / PROXY_LIST HTTP-SOCKS
#   direct = no proxy
#   auto   = list → core → clash (default)
# REGISTER_EGRESS=core
# Persist: python -m register_core nodes egress set core

CHATGPT_EMAIL_SOURCE=gmail_imap
CHATGPT_OTP_TIMEOUT=180

# Optional fixed URL (mainly with REGISTER_EGRESS=clash or direct override)
# CHATGPT_PROXY=http://127.0.0.1:7897
# CLASH_PROXY=http://127.0.0.1:7897

# HTTP/SOCKS pool (REGISTER_EGRESS=list|auto)
# CHATGPT_PROXY_LIST=http://user:pass@1.2.3.4:8080,http://user:pass@5.6.7.8:8080
# REGISTER_NODES_FILE=./nodes.json

# CHATGPT_PROXY_ROTATE_MODE=list
# CHATGPT_PROXY_ROTATE_EVERY=1
# CHATGPT_PROXY_ROTATE_REQUIRED=0
